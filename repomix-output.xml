}

.mic-press:active {
  animation: scale-press 0.15s ease-out both !important;
}

.gradient-text {
  background: linear-gradient(135deg, #ff8c42 0%, #ff4500 50%, #ff1a1a 100%);
  -webkit-background-clip: text;
