  border-radius: 2px;
  transform-origin: bottom;
}

.wave-bar:nth-child(1) { animation: wave-bar 0.6s ease-in-out infinite; }
.wave-bar:nth-child(2) { animation: wave-bar 0.6s ease-in-out infinite 0.1s; }
.wave-bar:nth-child(3) { animation: wave-bar 0.6s ease-in-out infinite 0.2s; }
.wave-bar:nth-child(4) { animation: wave-bar 0.6s ease-in-out infinite 0.15s; }
.wave-bar:nth-child(5) { animation: wave-bar 0.6s ease-in-out infinite 0.05s; }

.speaking-bar {
  width: 3px;
  background: linear-gradient(to top, #ff8c42, #fff);
  border-radius: 2px;
  transform-origin: bottom;
}

.speaking-bar:nth-child(1) { animation: speaking-bar 0.5s ease-in-out infinite; }
.speaking-bar:nth-child(2) { animation: speaking-bar 0.5s ease-in-out infinite 0.07s; }
.speaking-bar:nth-child(3) { animation: speaking-bar 0.5s ease-in-out infinite 0.14s; }
.speaking-bar:nth-child(4) { animation: speaking-bar 0.5s ease-in-out infinite 0.21s; }
.speaking-bar:nth-child(5) { animation: speaking-bar 0.5s ease-in-out infinite 0.07s; }
.speaking-bar:nth-child(6) { animation: speaking-bar 0.5s ease-in-out infinite 0.28s; }
.speaking-bar:nth-child(7) { animation: speaking-bar 0.5s ease-in-out infinite 0.14s; }

.dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ff6b00;
}

.dot:nth-child(1) { animation: dot-bounce 1.2s ease-in-out infinite; }
.dot:nth-child(2) { animation: dot-bounce 1.2s ease-in-out infinite 0.2s; }
.dot:nth-child(3) { animation: dot-bounce 1.2s ease-in-out infinite 0.4s; }

.flame-icon {
  display: inline-block;
