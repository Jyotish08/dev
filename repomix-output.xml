import { useState, useRef, useCallback, useEffect } from 'react'

type AppState = 'idle' | 'listening' | 'processing' | 'responded' | 'error'

// ── Roast bank ─────────────────────────────────────────────────────────────

const GENERIC_ROASTS = [
  "That trash talk was cute. Almost as cute as your team's last season stats — painfully bad.",
  "Bold talk from someone whose team's highlight reel fits on a Post-it note.",
  "I've seen better coordination at a middle school talent show than your team's offense.",
  "Your squad's so bad, even the mascot is looking for a trade.",
  "Keep dreaming, champ. Your team hasn't seen a trophy since dial-up internet was fast.",
  "You call that trash talk? My grandma roasts harder, and she doesn't even watch sports.",
  "Your team's defense is like a screen door on a submarine — decorative at best.",
  "The only thing worse than your team's record is the confidence you just showed.",
  "Twenty years of rebuilding. Any day now... any day. Keep the faith, buddy.",
  "I'd roast you harder, but your team already does that every single game.",
  "You must be really passionate about mediocrity, because your team has MASTERED it.",
  "That almost qualified as a threat. Just like your team almost qualifies as competition.",
  "Even your stadium's WiFi drops out during the fourth quarter. Can't blame it.",
  "Your team's greatest achievement this decade is selling overpriced hot dogs.",
  "I respect the passion. The delusion? That's free of charge.",
]

const KEYWORD_ROASTS: { keywords: string[]; roast: string }[] = [
  {
    keywords: ['patriots', 'brady', 'new england'],
    roast: "Brady left and your whole identity collapsed. He knew when to move on — unlike your fanbase.",
  },
  {
    keywords: ['cowboys', 'dallas', "america's team"],
    roast: "America's Team? More like America's most expensive disappointment. Jerry Jones has been 'one year away' for three decades.",
  },
  {
    keywords: ['lakers', 'lebron', 'los angeles lakers'],
    roast: "LeBron carried that team so long the rest of 'em forgot how to walk without him.",
  },
  {
    keywords: ['yankees', 'new york yankees'],
    roast: "Payroll of a small nation, personality of a tax audit. Congrats on buying another mediocre October.",
  },
  {
    keywords: ['knicks', 'new york knicks'],
    roast: "Knicks fans have more faith than any religious group on Earth. And roughly the same championship odds.",
  },
  {
    keywords: ['man city', 'manchester city', 'city'],
    roast: "Oh wow, the oil-money team wins again? Groundbreaking. Try doing it with a wage cap, champ.",
  },
  {
    keywords: ['arsenal', 'gunners'],
    roast: "Top four! Top four! Arsenal fans counting top-four finishes like they're trophies. Adorable delusion.",
  },
  {
    keywords: ['liverpool', 'reds'],
    roast: "'You'll never walk alone' — except to the trophy cabinet, apparently. That walk is very much solo.",
  },
  {
    keywords: ['real madrid', 'madrid'],
    roast: "Real Madrid: a transfer deadline day press conference that occasionally plays football.",
  },
  {
    keywords: ['barcelona', 'barca'],
    roast: "Still playing tiki-taka like it's 2010 while the rest of the world evolved. Cute.",
  },
  {
    keywords: ['golden state', 'warriors', 'steph', 'curry'],
    roast: "The Hamptons five era called — it's embarrassed by what's left of this roster.",
  },
  {
    keywords: ['celtics', 'boston celtics'],
    roast: "17 championships and somehow the most insufferable fanbase in basketball. Impressive.",
  },
  {
    keywords: ['heat', 'miami heat'],
    roast: "Miami Heat fans show up in the third quarter and leave in the fourth. The team followed suit.",
  },
  {
    keywords: ['red sox', 'boston red sox'],
    roast: "Broke an 86-year curse and still chose to be miserable about everything. Peak Boston energy.",
  },
  {
